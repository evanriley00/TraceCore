# Default quickstart uses SQLite so the app runs without Docker.
DATABASE_URL=sqlite:///./tracecore.db
REDIS_URL=redis://localhost:6379/0
JWT_SECRET=replace-this-with-a-long-secret
ACCESS_TOKEN_EXPIRE_MINUTES=120
RATE_LIMIT_PER_MINUTE=30
CACHE_TTL_SECONDS=900
MOCK_LLM_ENABLED=true
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
CONTROL_API_TOKEN=
CONTROL_STATE_PATH=.tracecore-control-state.json

# Optional production-style Postgres setting:
# DATABASE_URL=postgresql+psycopg://tracecore:tracecore@localhost:5432/tracecore
